{
  "name": "neighbr",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:deploy-api": "turbo run build --filter=@neighbr/deploy-api...",
    "build:deploy-workers": "turbo run build --filter=@neighbr/deploy-workers...",
    "build:backend": "turbo run build --filter=./apps/services/* --filter=@neighbr/db --filter=@neighbr/config --concurrency=4",
    "build:gateway": "npm run build --workspace=@neighbr/gateway",
    "build:web": "turbo run build --filter=web",
    "dev": "turbo run dev --filter=./apps/services/* --filter=./apps/web --filter=./apps/gateway",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "apps/deploy/*",
    "apps/services/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "bullmq": "^5.76.10",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0"
  }
}
