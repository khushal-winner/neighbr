generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model City {
  id          String           @id @default(uuid())
  name        String
  country     String
  createdAt   DateTime         @default(now())
  communities MicroCommunity[]
}

model MicroCommunity {
  id             String                   @id @default(uuid())
  name           String
  cityId         String
  blockCaptainId String?
  residentCount  Int                      @default(0)
  lastDigestAt   DateTime?
  createdAt      DateTime                 @default(now())
  boundary       Unsupported("geometry")?
  city           City                     @relation(fields: [cityId], references: [id])
  posts          Post[]
  users          User[]
  polls          Poll[]
  pinnedPostId   String? // block captain sets this
}

model Poll {
  id          String         @id @default(uuid())
  communityId String
  community   MicroCommunity @relation(fields: [communityId], references: [id])
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id])
  question    String
  closesAt    DateTime? //null = open indefinitely
  createdAt   DateTime       @default(now())
  options     PollOption[]
  votes       PollVote[]
  feedPost    Post?
}

model PollOption {
  id     String     @id @default(uuid())
  pollId String
  poll   Poll       @relation(fields: [pollId], references: [id])
  text   String
  votes  PollVote[]
}

model PollVote {
  id        String     @id @default(uuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id])
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id])
  userId    String
  createdAt DateTime   @default(now())

  @@unique([pollId, userId]) // one vote per user per poll
}

model User {
  id                String                   @id @default(uuid())
  email             String                   @unique
  passwordHash      String
  displayName       String
  avatarUrl         String?
  verificationLevel VerificationLevel          @default(unverified)
  trustScore        Int                      @default(0)
  communityId       String?
  notificationPrefs Json                     @default("{}")
  createdAt         DateTime                 @default(now())
  homeLocation      Unsupported("geometry")?
  publicLocation    Unsupported("geometry")?
  posts             Post[]
  fcmTokens         FcmToken[]
  community         MicroCommunity?          @relation(fields: [communityId], references: [id])
  chatMessages      ChatMessage[]
  createdPolls      Poll[]

  @@index([homeLocation], map: "idx_user_home_location", type: Gist)
}

model Post {
  id               String         @id @default(uuid())
  authorId         String
  communityId      String
  type             String
  title            String
  body             String
  imageUrls        String[]       @default([])
  moderationStatus String         @default("pending")
  upvotes          Int            @default(0)
  flagCount        Int            @default(0)
  pollId           String?        @unique
  poll             Poll?          @relation(fields: [pollId], references: [id])
  createdAt        DateTime       @default(now())
  interactions     PostInteraction[]
  author           User           @relation(fields: [authorId], references: [id])
  community        MicroCommunity @relation(fields: [communityId], references: [id])
}

model PostInteraction {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  type      String   // "upvote" or "flag"
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])

  @@unique([postId, userId, type]) // one upvote + one flag per user per post
}


model ModerationDecision {
  id        String   @id @default(uuid())
  postId    String
  decision  String
  score     Float
  decidedAt DateTime @default(now())
}

model TrustScoreEvent {
  id         String   @id @default(uuid())
  userId     String
  eventType  String
  delta      Int
  occurredAt DateTime @default(now())
}

model ChatThread {
  id           String            @id @default(uuid())
  type         String            @default("dm") // "dm" or "group"
  communityId  String? // only set for group threads
  createdAt    DateTime          @default(now())
  messages     ChatMessage[]
  participants ChatParticipant[]
}

model ChatParticipant {
  id       String     @id @default(uuid())
  threadId String
  thread   ChatThread @relation(fields: [threadId], references: [id])
  userId   String
  joinedAt DateTime   @default(now())

  @@unique([threadId, userId]) // one row per user per thread
}

model ChatMessage {
  id        String     @id @default(uuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id])
  senderId  String
  sender    User       @relation(fields: [senderId], references: [id])
  body      String
  readAt    DateTime?
  createdAt DateTime   @default(now())
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

enum VerificationLevel {
  unverified
  email_verified
  address_verified
  postcard_verified
}

model FcmToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
