@baseUrl = http://localhost:3001
@email = testuser@example.com
@password = password123

### ───────────────────────────────
### HEALTH
### ───────────────────────────────

### 1. Health check
GET {{baseUrl}}/health


### ───────────────────────────────
### AUTH
### ───────────────────────────────

### 2. Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}",
  "displayName": "Test User"
}

###

### 3. Register — duplicate email (should return 409)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}",
  "displayName": "Test User"
}

###

### 4. Register — weak password (should return 400)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "weak@example.com",
  "password": "123",
  "displayName": "Weak"
}

###

### 5. Login — valid credentials
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

###

### 6. Login — wrong password (should return 401)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "wrongpassword"
}

###

### 7. Login — email doesn't exist (should return 401, NOT 404)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "ghost@example.com",
  "password": "password123"
}


### ───────────────────────────────
