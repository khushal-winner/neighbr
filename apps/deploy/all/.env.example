NODE_ENV=production
PORT=10000
GATEWAY_PORT=8080

DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
JWT_SECRET=minimum_32_characters_long_secret_here
COOKIE_SECRET=minimum_32_characters_long_secret_here
FRONTEND_URL=https://your-app.vercel.app

REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

KAFKA_BROKER=YOUR_REDPANDA_HOST:9092
KAFKA_USERNAME=neighbr
KAFKA_PASSWORD=YOUR_KAFKA_PASSWORD

RABBITMQ_URL=amqps://user:pass@host.cloudamqp.com/vhost
INTERNAL_SECRET=long_random_secret
WEBHOOK_SECRET=webhook_hmac_secret

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Neighbr <noreply@yourdomain.com>

POST_SERVICE_URL=http://127.0.0.1:10000

RESEND_API_KEY=re_xxxxxxxx
DIGEST_FROM_EMAIL=onboarding@resend.dev
DIGEST_CRON=0 6 * * 0
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
PERSPECTIVE_API_KEY=
RADIUS_METERS=500
NOTIFICATION_WINDOW_MS=3600000
