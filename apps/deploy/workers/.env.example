# Copy to .env — POST_SERVICE_URL must point at neighbr-api (local port 10000 or Render URL).

NODE_ENV=development

DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

JWT_SECRET=minimum_32_characters_long_secret_here

REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

KAFKA_BROKER=YOUR_REDPANDA_HOST:9092
KAFKA_USERNAME=neighbr
KAFKA_PASSWORD=YOUR_KAFKA_PASSWORD

RABBITMQ_URL=amqps://user:pass@host.cloudamqp.com/vhost

POST_SERVICE_URL=http://localhost:10000
INTERNAL_SECRET=change_this_to_a_long_random_value

RESEND_API_KEY=re_xxxxxxxx
DIGEST_FROM_EMAIL=onboarding@resend.dev
DIGEST_CRON=0 6 * * 0

FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

PERSPECTIVE_API_KEY=YOUR_GOOGLE_PERSPECTIVE_KEY

RADIUS_METERS=500
NOTIFICATION_WINDOW_MS=3600000
