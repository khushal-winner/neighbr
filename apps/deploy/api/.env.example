# Copy to .env — values from your Neon / Upstash / Redpanda / CloudAMQP dashboards.

NODE_ENV=development
PORT=10000

DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

JWT_SECRET=minimum_32_characters_long_secret_here
COOKIE_SECRET=minimum_32_characters_long_secret_here

FRONTEND_URL=http://localhost:3000

REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

KAFKA_BROKER=YOUR_REDPANDA_HOST:9092
KAFKA_USERNAME=neighbr
KAFKA_PASSWORD=YOUR_KAFKA_PASSWORD

RABBITMQ_URL=amqps://user:pass@host.cloudamqp.com/vhost

INTERNAL_SECRET=change_this_to_a_long_random_value
WEBHOOK_SECRET=test_secret

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Neighbr <noreply@yourdomain.com>
